export PGHOST=127.0.0.1
export PGPORT=5432
export PGDATABASE=cloud_security
export PGUSER=secadmin
export PGPASSWORD=changeme

export AWS_PROFILE=default
export AWS_DEFAULT_REGION=us-east-1
export AWS_ACCOUNT_ID=your-account-id-here

export SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# LLM model via Amazon Bedrock (must be enabled in your account)
# Options: meta.llama3-70b-instruct-v1:0 | anthropic.claude-3-haiku-20240307-v1:0
export BEDROCK_MODEL_ID=meta.llama3-70b-instruct-v1:0
