# accounts.yaml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to accounts.yaml and fill in your AWS account details.
# accounts.yaml is gitignored — never commit real account IDs.
#
# Auth methods (pick one per account):
#   profile:   uses a named AWS CLI profile from ~/.aws/credentials
#   role_arn:  assumes a cross-account IAM role via STS (recommended for prod)
# ─────────────────────────────────────────────────────────────────────────────

accounts:
  - id: "123456789012"          # your AWS account ID
    name: production
    region: us-east-1
    role_arn: arn:aws:iam::123456789012:role/CloudSecurityAgentRole

  # Example: second account via CLI profile
  # - id: "111122223333"
  #   name: staging
  #   region: us-east-1
  #   profile: staging-profile

  # Example: cross-account with external ID
  # - id: "444455556666"
  #   name: dev
  #   region: ap-south-1
  #   role_arn: arn:aws:iam::444455556666:role/SecurityAuditRole
  #   external_id: your-external-id
  #   session_duration: 3600
