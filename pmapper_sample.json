    "target_arn": "arn:aws:iam::123456789012:role/AdminRole",
    "is_admin_path": true,
    "detail": {
      "source": "arn:aws:iam::123456789012:user/ci-deploy-bot",
      "destination": "arn:aws:iam::123456789012:role/AdminRole",
      "path": [
        {"arn": "arn:aws:iam::123456789012:user/ci-deploy-bot", "action": "iam:PassRole"},
        {"arn": "arn:aws:iam::123456789012:role/AdminRole"}
      ]
    }
  },
  {
    "title": "DevOpsRole can escalate to Admin via sts:AssumeRole",
