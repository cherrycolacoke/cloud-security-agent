  {
    "title": "WebServerRole can read secrets from SecretsManager",
    "description": "WebServerRole has secretsmanager:GetSecretValue permission with a wildcard resource. An attacker can read all secrets including database passwords and API keys.",
    "source_arn": "arn:aws:iam::123456789012:role/WebServerRole",
    "target_arn": "arn:aws:iam::123456789012:role/DevOpsRole",
    "is_admin_path": false,
    "detail": {
      "source": "arn:aws:iam::123456789012:role/WebServerRole",
      "destination": "arn:aws:iam::123456789012:role/DevOpsRole",
      "path": [
